{
  "name": "sol-hud",
  "version": "0.17.1",
  "main": "main.js",
  "scripts": {
    "check": "node --check main.js && node --check preload.js && node --check renderer.js && node --check storage/playerStore.js && node --check storage/questStore.js",
    "test": "npm run check",
    "start": "electron .",
    "build": "electron-builder --win --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.lotoos0.sol-hud",
    "productName": "SOL HUD",
    "directories": {
      "output": "dist"
    },
    "artifactName": "SOL-HUD-Setup-${version}.${ext}",
    "files": [
      "**/*",
      "!sessions/**",
      "!.git/**",
      "!.github/**"
    ],
    "win": {
      "icon": "data/Icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "SOL-HUD-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "lotoos0",
      "repo": "sol_hud"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    }
  }
}
